@echo off
echo ========================================
echo  Install VS Code Extensions
echo  Untuk File Explorer yang Rapi & Bagus
echo ========================================
echo.

echo [1/3] Installing Material Icon Theme...
code --install-extension PKief.material-icon-theme

echo.
echo [2/3] Installing vscode-icons (alternatif)...
code --install-extension vscode-icons-team.vscode-icons

echo.
echo [3/3] Installing Material Theme (warna editor)...
code --install-extension Equinusocio.vsc-material-theme

echo.
echo ========================================
echo  SELESAI!
echo ========================================
echo.
echo Cara Aktifkan:
echo 1. Tekan Ctrl+Shift+P
echo 2. Ketik: "File Icon Theme"
echo 3. Pilih: "Material Icon Theme"
echo.
echo Atau untuk warna tema:
echo 1. Tekan Ctrl+Shift+P
echo 2. Ketik: "Color Theme"
echo 3. Pilih tema yang kamu suka
echo.
pause
